# Copy to .env on the VM and fill in real values. .env is NEVER committed.
# cp .env.example .env

# --- Autonomous Database -----------------------------------------------------
# The TNS alias comes from tnsnames.ora inside the unzipped wallet
# (techmind_high / techmind_tp / techmind_tpurgent). TNS_ADMIN points at the
# mounted wallet, so the alias alone is enough.
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@techmind_tp?TNS_ADMIN=/app/wallet
SPRING_DATASOURCE_USERNAME=ADMIN
SPRING_DATASOURCE_PASSWORD=

# --- Object Storage ----------------------------------------------------------
# Namespace is on the tenancy details page. No keys here: the VM authenticates
# with Instance Principal (docs/OCI-setup.md section 5).
OCI_NAMESPACE=
MODEL_BUCKET=techmind-data
